# ========================================
# Ecomera Order Service Environment
# ========================================

# ---------------------------------------
# Server & Spring Configuration
# ---------------------------------------
SERVER_PORT=8084
SPRING_PROFILES_ACTIVE=dev

# ---------------------------------------
# Eureka & Config Server
# ---------------------------------------
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost
CONFIG_SERVER_HOST=localhost
CONFIG_SERVER_PORT=8888

# ---------------------------------------
# Vault (secrets: db/password, redis/password)
# ---------------------------------------
# Get token after first vault init: docker logs ecomera-infra-vault 2>&1 | grep "Root Token"
VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------
# Database (password fetched from Vault)
# ---------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecomera_order
DB_USERNAME=postgres
DDL_AUTO=none
SHOW_SQL=false
LIQUIBASE_ENABLED=true

# ---------------------------------------
# Redis (password fetched from Vault)
# ---------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
